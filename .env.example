# Database
DATABASE_URL=postgresql://p2p_user:p2p_pass@localhost:5432/p2p_automation

# Bybit API - Testnet (рекомендуется для разработки)
# Получите API ключи на https://testnet.bybit.com/
BYBIT_API_KEY=your_testnet_api_key_here
BYBIT_API_SECRET=your_testnet_api_secret_here
BYBIT_TESTNET=True  # Всегда true для безопасной разработки
USE_MOCK_DATA=False  # Использовать реальный testnet API

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider (openai/anthropic/groq/together/mistral/local/openrouter)
AI_PROVIDER=openrouter

# AI API Keys (set only what you use)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here
TOGETHER_API_KEY=your_together_key_here
MISTRAL_API_KEY=your_mistral_key_here

# OpenRouter (unified AI API - recommended)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Local LLM (if using local provider)
LOCAL_LLM_URL=http://localhost:11434

# AI Mock Mode (use mock AI agents instead of real APIs)
USE_AI_MOCK=False

# Processing API (mock for now)
PROCESSING_API_URL=https://api.processing.example.com
PROCESSING_API_KEY=your_processing_key_here

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# MessageProcessor
MESSAGE_MAX_LENGTH=2000
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=15
MAX_VIOLATIONS_BEFORE_BAN=5

# Webhook
WEBHOOK_URL=https://your-webhook.com/notify